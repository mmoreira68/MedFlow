# Copie este arquivo para .env e preencha os valores
# O arquivo .env NUNCA deve ser commitado no git

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=troque-por-uma-chave-segura-e-longa

# True para desenvolvimento local, False em produção
DEBUG=True

# Hosts permitidos (separados por vírgula)
# Produção exemplo: seuapp.onrender.com,www.seuapp.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens confiáveis para CSRF (obrigatório em produção com HTTPS)
# Produção exemplo: https://seuapp.onrender.com
CSRF_TRUSTED_ORIGINS=

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Cole aqui a connection string do Supabase (Session Mode, porta 5432)
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://usuario:senha@db.xxxx.supabase.co:5432/postgres
